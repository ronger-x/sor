# ===== 必填：上游音乐 API =====
NUXT_MUSIC_API_URL=your-music-api-url
NUXT_MUSIC_API_KEY=your-music-api-key

# ===== 可选：云曲库上传 =====
# 设置上传口令后，/library 上传入口才会启用
NUXT_UPLOAD_PASSWORD=
# 上传会话签名密钥（必须显式配置，不再回退到 NUXT_MUSIC_API_KEY）
NUXT_UPLOAD_SESSION_SECRET=
# 上传会话有效期（秒），默认 43200（12 小时），最小 300
NUXT_UPLOAD_SESSION_TTL_SECONDS=43200
# 临时上传卡签名密钥，留空时回退到 NUXT_UPLOAD_SESSION_SECRET
NUXT_UPLOAD_CARD_SECRET=
# 临时上传卡有效期（秒），默认 3600，最小 60
NUXT_UPLOAD_CARD_TTL_SECONDS=3600
# 分享链接 / 公众号回复中展示的上传入口地址，默认相对路径 /library
NUXT_UPLOAD_PUBLIC_URL=/library

# ===== 可选：微信公众号集成（自动发放上传卡）=====
# 公众号服务器配置的 Token，用于校验回调签名
NUXT_WECHAT_MP_TOKEN=
# 公众号二维码图片地址，留空则上传页显示占位图
NUXT_WECHAT_QR_URL=
# 公众号显示名称
NUXT_WECHAT_NAME=
